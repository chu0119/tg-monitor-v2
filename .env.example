# TG 监控告警系统 - 环境配置
# 复制此文件为 .env 并填入实际值

# ==================== 数据库配置 ====================
DATABASE_TYPE=mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=tg_monitor

# ==================== Telegram API ====================
# 访问 https://my.telegram.org/apps 获取
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# ==================== 服务器配置 ====================
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# ==================== 安全配置 ====================
# 生产环境请修改此密钥
SECRET_KEY=please-change-this-in-production
# Token 有效期（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=240

# ==================== CORS 配置 ====================
# 生产环境请设置具体域名，如：https://yourdomain.com
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=*

# ==================== WebSocket 令牌（可选）====================
# 设置后 WebSocket 连接需要此令牌
# WS_TOKEN=your_ws_token

# ==================== 代理配置（可选）====================
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# SOCKS5_PROXY=socks5://127.0.0.1:7891

# ==================== 通知配置（可选）====================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=your_email@gmail.com
