#!/bin/bash
# ============================================================
#  TG Monitor (听风追影) - 统一管理脚本
#  用法: ./tg [command]
#
#  无参数运行时显示交互菜单，也可直接传参:
#    ./tg install|uninstall|start|stop|restart|status|logs|health|backup|update|fix
# ============================================================

set -e

# ── 配置 ──
PROJECT_DIR="/home/test/tg-monitor"
BACKEND_DIR="$PROJECT_DIR/backend"
FRONTEND_DIR="$PROJECT_DIR/frontend"
BACKUP_DIR="$PROJECT_DIR/backups"
LOG_DIR="$PROJECT_DIR/logs"
ENV_FILE="$BACKEND_DIR/.env"

BACKEND_SERVICE="tgmonitor-backend"
NGINX_SERVICE="nginx"
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── 颜色 ──
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

info()    { echo -e "  ${GREEN}✓${NC} $*"; }
warn()    { echo -e "  ${YELLOW}!${NC} $*"; }
error()   { echo -e "  ${RED}✗${NC} $*"; }
step()    { echo -e "\n${CYAN}━━━ $* ━━━${NC}"; }

# ── 辅助函数 ──

get_env() {
    grep "^$1=" "$ENV_FILE" 2>/dev/null | cut -d'=' -f2
}

check_svc() {
    systemctl is-active --quiet "$1" 2>/dev/null && echo -e "${GREEN}●${NC}" || echo -e "${RED}○${NC}"
}

check_port() {
    ss -tlnp 2>/dev/null | grep -q ":$1 " && echo -e "${GREEN}●${NC}" || echo -e "${RED}○${NC}"
}

check_http() {
    local code=$(curl -s -o /dev/null -w "%{http_code}" "$1" 2>/dev/null)
    [ "$code" = "200" ] && echo -e "${GREEN}●${NC}" || echo -e "${RED}○${NC}"
}

# ── 命令实现 ──

cmd_install() {
    step "1/6 检查环境"
    command -v python3 &>/dev/null && info "Python3: $(python3 --version 2>&1 | cut -d' ' -f2)" || { error "Python3 未安装"; exit 1; }
    command -v mysql &>/dev/null && info "MySQL 已安装" || { warn "安装 MySQL..."; apt-get update -qq && apt-get install -y -qq mysql-server; }
    command -v nginx &>/dev/null && info "Nginx 已安装" || { warn "安装 Nginx..."; apt-get update -qq && apt-get install -y -qq nginx; }

    step "2/6 安装依赖"
    cd "$BACKEND_DIR" && pip3 install --break-system-packages -r requirements.txt -q 2>/dev/null || pip3 install -r requirements.txt -q
    info "后端依赖已安装"

    step "3/6 构建前端"
    cd "$FRONTEND_DIR"
    if command -v npm &>/dev/null; then
        npm install -q 2>/dev/null && npm run build 2>/dev/null && info "前端构建完成" || warn "前端构建失败"
    else
        warn "npm 未安装，跳过"
    fi

    step "4/6 配置数据库"
    local u=$(get_env MYSQL_USER) p=$(get_env MYSQL_PASSWORD) d=$(get_env MYSQL_DATABASE)
    if [ -n "$u" ] && [ -n "$d" ]; then
        mysql -u root -e "CREATE DATABASE IF NOT EXISTS \`$d\` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;" 2>/dev/null
        mysql -u root -e "CREATE USER IF NOT EXISTS '$u'@'localhost' IDENTIFIED BY '$p'; GRANT ALL ON \`$d\`.* TO '$u'@'localhost'; FLUSH PRIVILEGES;" 2>/dev/null
        info "数据库就绪"
    fi

    step "5/6 注册服务"
    cat > /etc/systemd/system/$BACKEND_SERVICE.service << 'SVCEOF'
[Unit]
Description=TG Monitor Backend
After=network.target mysql.service

[Service]
Type=simple
User=root
WorkingDirectory=/home/test/tg-monitor/backend
ExecStart=/usr/bin/python3 -m gunicorn app.main:app --bind 0.0.0.0:8000 --workers 4 --worker-class uvicorn.workers.UvicornWorker --timeout 120 --keep-alive 30 --max-requests 10000 --max-requests-jitter 1000
Restart=always
RestartSec=5
MemoryMax=8G
LimitNOFILE=65535
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
SVCEOF
    systemctl daemon-reload && systemctl enable $BACKEND_SERVICE
    info "服务已注册"

    step "6/6 启动"
    cmd_start
    echo -e "\n  ${GREEN}安装完成！${NC}"
    echo -e "  访问: ${CYAN}http://$(hostname -I | awk '{print $1}'):$FRONTEND_PORT${NC}\n"
}

cmd_uninstall() {
    systemctl stop $BACKEND_SERVICE 2>/dev/null; systemctl disable $BACKEND_SERVICE 2>/dev/null
    rm -f /etc/systemd/system/$BACKEND_SERVICE.service; systemctl daemon-reload
    info "服务已卸载（项目文件未删除）"
}

cmd_start() {
    systemctl is-active --quiet mysql || { systemctl start mysql; info "MySQL 已启动"; }
    systemctl is-active --quiet $BACKEND_SERVICE || { systemctl start $BACKEND_SERVICE; info "后端已启动"; }
    systemctl is-active --quiet $NGINX_SERVICE || { systemctl start $NGINX_SERVICE; info "Nginx 已启动"; }
    sleep 2
}

cmd_stop() {
    systemctl stop $BACKEND_SERVICE 2>/dev/null && info "后端已停止" || true
    systemctl stop $NGINX_SERVICE 2>/dev/null && info "Nginx 已停止" || true
}

cmd_restart() {
    systemctl restart $BACKEND_SERVICE && info "后端已重启"
    systemctl reload $NGINX_SERVICE 2>/dev/null && info "Nginx 已重载"
    sleep 3
}

cmd_status() {
    local mysql_s=$(check_svc mysql)
    local backend_s=$(check_svc $BACKEND_SERVICE)
    local nginx_s=$(check_svc $NGINX_SERVICE)
    local backend_p=$(check_port $BACKEND_PORT)
    local frontend_p=$(check_port $FRONTEND_PORT)
    local api_s=$(check_http http://localhost:$BACKEND_PORT/health)
    local web_s=$(check_http http://localhost:$FRONTEND_PORT/)
    local workers=$(ps aux 2>/dev/null | grep 'gunicorn.*worker' | grep -v grep | wc -l)
    local disk=$(df -h / | awk 'NR==2 {print $3"/"$2" ("$5")"}')
    local mem=$(free -h | awk '/Mem:/ {print $3"/"$2}')

    echo -e "\n  ${BOLD}组件${NC}         状态   端口"
    echo "  ─────────── ──── ────"
    printf "  %-11s  %b    %b\n" "MySQL" "$mysql_s" "$(check_port 3306)"
    printf "  %-11s  %b    %b\n" "后端" "$backend_s" "$backend_p"
    printf "  %-11s  %b    %b\n" "Nginx" "$nginx_s" "$frontend_p"
    echo ""
    echo -e "  ${BOLD}接口${NC}         状态"
    echo "  ─────────── ────"
    printf "  %-11s  %b\n" "API" "$api_s"
    printf "  %-11s  %b\n" "前端" "$web_s"
    echo ""
    echo -e "  ${BOLD}资源${NC}"
    echo "  ───────────────────────"
    echo "  内存:  $mem"
    echo "  磁盘:  $disk"
    echo "  Worker: $workers"
    echo ""
}

cmd_logs() {
    journalctl -u $BACKEND_SERVICE -f --no-pager
}

cmd_health() {
    local r=$(curl -s http://localhost:$BACKEND_PORT/health 2>/dev/null)
    if [ -z "$r" ]; then error "API 无响应"; return 1; fi
    echo "$r" | python3 -c "
import sys,json
d=json.load(sys.stdin)
r=d['resources']
t=d['telegram']
print(f\"  状态:     {d['status']}\")
print(f\"  数据库:   {'连接' if d['database']['connected'] else '断开'}\")
print(f\"  TG客户端: {t['clients_count']} 个\")
print(f\"  监控任务: {t['active_monitors']} 个\")
print(f\"  进程内存: {r['process_memory_mb']}MB\")
print(f\"  系统内存: {r['memory_percent']}%\")
"
}

cmd_backup() {
    local ts=$(date +%Y%m%d_%H%M%S)
    local dst="$BACKUP_DIR/manual_$ts"
    mkdir -p "$dst"
    cp -r "$BACKEND_DIR/app" "$dst/" 2>/dev/null
    cp -r "$FRONTEND_DIR/src" "$dst/frontend_src/" 2>/dev/null
    cp "$ENV_FILE" "$dst/" 2>/dev/null
    cp "$FRONTEND_DIR/package.json" "$dst/" 2>/dev/null
    local u=$(get_env MYSQL_USER) p=$(get_env MYSQL_PASSWORD) d=$(get_env MYSQL_DATABASE)
    [ -n "$u" ] && mysqldump -u "$u" -p"$p" "$d" > "$dst/db.sql" 2>/dev/null
    info "备份完成: $dst ($(du -sh "$dst" | cut -f1))"
}

cmd_update() {
    cd "$PROJECT_DIR"
    [ -d ".git" ] && { git pull origin main; info "代码已更新"; }
    cd "$BACKEND_DIR" && pip3 install --break-system-packages -r requirements.txt -q 2>/dev/null
    cd "$FRONTEND_DIR" && command -v npm &>/dev/null && { npm install -q 2>/dev/null; npm run build 2>/dev/null; info "前端已构建"; }
    cmd_restart
}

cmd_fix() {
    local n=0
    systemctl is-active --quiet mysql || { systemctl start mysql 2>/dev/null && info "MySQL 已恢复" && n=$((n+1)); }
    systemctl is-active --quiet $BACKEND_SERVICE || { systemctl start $BACKEND_SERVICE 2>/dev/null && info "后端已恢复" && n=$((n+1)); }
    local c=$(curl -s -o /dev/null -w "%{http_code}" http://localhost:$BACKEND_PORT/health 2>/dev/null)
    [ "$c" != "200" ] && { systemctl restart $BACKEND_SERVICE; sleep 5; info "后端已重启"; n=$((n+1)); }
    systemctl is-active --quiet $NGINX_SERVICE || { systemctl start $NGINX_SERVICE 2>/dev/null && info "Nginx 已恢复" && n=$((n+1)); }
    local old=$(find "$LOG_DIR" -name "*.zip" -mtime +7 -delete 2>/dev/null; echo $?)
    [ "$n" -gt 0 ] && info "修复了 $n 个问题" || info "系统正常"
}

# ── 交互菜单 ──

show_banner() {
    clear
    echo -e "${CYAN}${BOLD}"
    echo "  ╔═══════════════════════════════════════╗"
    echo "  ║     听风追影 · TG Monitor 管理工具    ║"
    echo "  ╚═══════════════════════════════════════╝"
    echo -e "${NC}"
}

show_menu() {
    echo -e "  ${BOLD}服务管理${NC}"
    echo "  ───────────────────────────────────────"
    echo -e "  ${GREEN}1)${NC} 启动服务        ${GREEN}2)${NC} 停止服务"
    echo -e "  ${GREEN}3)${NC} 重启服务        ${GREEN}4)${NC} 查看状态"
    echo ""
    echo -e "  ${BOLD}运维工具${NC}"
    echo "  ───────────────────────────────────────"
    echo -e "  ${BLUE}5)${NC} 查看日志        ${BLUE}6)${NC} 健康检查"
    echo -e "  ${BLUE}7)${NC} 手动备份        ${BLUE}8)${NC} 更新代码"
    echo -e "  ${BLUE}9)${NC} 自动修复"
    echo ""
    echo -e "  ${BOLD}部署安装${NC}"
    echo "  ───────────────────────────────────────"
    echo -e "  ${YELLOW}i)${NC} 一键安装        ${YELLOW}u)${NC} 卸载服务"
    echo ""
    echo -e "  ${DIM}q) 退出${NC}"
    echo ""
    echo -ne "  请选择 [1-9/i/u/q]: "
}

run_choice() {
    local choice="$1"
    case "$choice" in
        1) cmd_start; cmd_status ;;
        2) cmd_stop ;;
        3) cmd_restart; cmd_status ;;
        4) cmd_status ;;
        5) cmd_logs ;;
        6) cmd_health ;;
        7) cmd_backup ;;
        8) cmd_update ;;
        9) cmd_fix ;;
        i|I) cmd_install ;;
        u|U) cmd_uninstall ;;
        q|Q) echo -e "\n  ${DIM}已退出${NC}\n"; exit 0 ;;
        *) warn "无效选项: $choice" ;;
    esac
}

# ── 主入口 ──

if [ -n "${1:-}" ]; then
    # 命令行模式
    case "$1" in
        install)    cmd_install ;;
        uninstall)  cmd_uninstall ;;
        start)      cmd_start ;;
        stop)       cmd_stop ;;
        restart)    cmd_restart ;;
        status)     cmd_status ;;
        logs)       cmd_logs ;;
        health)     cmd_health ;;
        backup)     cmd_backup ;;
        update)     cmd_update ;;
        fix)        cmd_fix ;;
        help|-h|--help) echo "用法: $0 [install|uninstall|start|stop|restart|status|logs|health|backup|update|fix]"; exit 0 ;;
        *)          error "未知命令: $1"; echo "用法: $0 [command] 或 $0 (交互菜单)"; exit 1 ;;
    esac
else
    # 交互菜单模式
    while true; do
        show_banner
        show_menu
        read -r choice
        show_banner
        echo -e "  ${DIM}执行中...${NC}\n"
        run_choice "$choice"
        echo ""
        echo -ne "  ${DIM}按 Enter 返回菜单...${NC}"
        read -r
    done
fi
